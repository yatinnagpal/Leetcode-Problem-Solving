class Solution:
    def topKFrequent(self, nums: List[int], k: int) -> List[int]:
        mpp = {}
        for val in nums:
            mpp[val] = mpp.get(val, 0) + 1
        sorted_items = sorted(mpp.items(), key = lambda x:x[1], reverse=True)
        res = []
        for i in range(k):
            res.append(sorted_items[i][0])
        return res
        
